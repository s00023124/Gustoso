{
  "info": {
    "name": "Gustoso API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{token}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token",   "value": "INCOLLA_QUI_IL_TOKEN_JWT" }
  ],
  "item": [

    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"mario\",\n  \"email\": \"mario@example.com\",\n  \"telefono\": \"3331234567\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('token', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },

    {
      "name": "Utenti",
      "item": [
        {
          "name": "GET tutti gli utenti (ADMIN)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/utenti", "host": ["{{baseUrl}}"], "path": ["utenti"] }
          }
        },
        {
          "name": "GET utente per id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/utenti/1", "host": ["{{baseUrl}}"], "path": ["utenti","1"] }
          }
        },
        {
          "name": "POST crea utente (ADMIN)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/utenti", "host": ["{{baseUrl}}"], "path": ["utenti"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"luigi_creator\",\n  \"email\": \"luigi@example.com\",\n  \"telefono\": \"3339876543\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "PUT aggiorna utente",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/utenti/1", "host": ["{{baseUrl}}"], "path": ["utenti","1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"mario_aggiornato\",\n  \"email\": \"mario@example.com\",\n  \"telefono\": \"3331234567\",\n  \"immagineProfilo\": null\n}"
            }
          }
        },
        {
          "name": "PUT upload immagine profilo",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/utenti/1/immagine", "host": ["{{baseUrl}}"], "path": ["utenti","1","immagine"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "" }
              ]
            }
          }
        },
        {
          "name": "DELETE elimina utente (ADMIN)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/utenti/1", "host": ["{{baseUrl}}"], "path": ["utenti","1"] }
          }
        }
      ]
    },

